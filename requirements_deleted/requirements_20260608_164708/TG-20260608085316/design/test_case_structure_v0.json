{
  "main_functions": [
    {
      "function_id": "FUNC001",
      "function_name": "User Registration",
      "description": "Allows user to create an account using email and password with validation and business rules.",
      "related_requirement_ids": [
        "FR001"
      ],
      "sub_functions": [
        {
          "sub_function_id": "SUB001",
          "sub_function_name": "Email Validation",
          "description": "Validates email format and uniqueness during registration.",
          "related_requirement_ids": [
            "FR001",
            "VAL001",
            "VAL006",
            "BR001"
          ],
          "test_categories": [
            {
              "category_id": "CAT001",
              "category_name": "Email Format Validation",
              "test_intent": "Verify that email must contain '@' and a domain, and that invalid formats are rejected with meaningful inline error messages.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL001",
                "VAL007"
              ]
            },
            {
              "category_id": "CAT002",
              "category_name": "Email Uniqueness Validation",
              "test_intent": "Verify that duplicate email addresses are rejected with a meaningful inline error message.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL006",
                "VAL007",
                "BR001"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB002",
          "sub_function_name": "Password Validation",
          "description": "Validates password against all defined rules including length, character requirements, and restrictions.",
          "related_requirement_ids": [
            "FR001",
            "BR002",
            "BR003",
            "BR004",
            "BR005",
            "BR007",
            "VAL002",
            "VAL003",
            "VAL004",
            "VAL005"
          ],
          "test_categories": [
            {
              "category_id": "CAT003",
              "category_name": "Password Length Validation",
              "test_intent": "Verify that password length is between 8 and 12 characters inclusive, and that invalid lengths are rejected with meaningful inline error messages.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL002",
                "VAL007",
                "BR002"
              ]
            },
            {
              "category_id": "CAT004",
              "category_name": "Password Character Requirements",
              "test_intent": "Verify that password contains at least one uppercase letter, one lowercase letter, one digit, and one special character from the allowed set.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL003",
                "BR003"
              ]
            },
            {
              "category_id": "CAT005",
              "category_name": "Password Space Restrictions",
              "test_intent": "Verify that consecutive spaces are forbidden and that leading/trailing spaces are not trimmed.",
              "priority": "Medium",
              "related_requirement_ids": [
                "VAL004",
                "BR004",
                "BR007"
              ]
            },
            {
              "category_id": "CAT006",
              "category_name": "Password Email Prefix Restriction",
              "test_intent": "Verify that password does not contain the user's email prefix or username.",
              "priority": "Medium",
              "related_requirement_ids": [
                "VAL005",
                "BR005"
              ]
            }
          ]
        }
      ]
    },
    {
      "function_id": "FUNC002",
      "function_name": "Email Verification",
      "description": "Handles sending and resending of verification link, and verification process before first login.",
      "related_requirement_ids": [
        "FR002",
        "FR003",
        "FR004",
        "BR006",
        "DEP001",
        "DEP002"
      ],
      "sub_functions": [
        {
          "sub_function_id": "SUB003",
          "sub_function_name": "Initial Verification Link Sending",
          "description": "System sends a unique verification link via email immediately after registration.",
          "related_requirement_ids": [
            "FR003",
            "DEP001"
          ],
          "test_categories": [
            {
              "category_id": "CAT007",
              "category_name": "Verification Link Generation and Delivery",
              "test_intent": "Verify that a unique verification link is generated and sent via email immediately after successful registration.",
              "priority": "High",
              "related_requirement_ids": [
                "FR003",
                "DEP001"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB004",
          "sub_function_name": "Verification Link Expiration",
          "description": "Verification link is valid for 24 hours.",
          "related_requirement_ids": [
            "BR006"
          ],
          "test_categories": [
            {
              "category_id": "CAT008",
              "category_name": "Link Expiration Handling",
              "test_intent": "Verify that the verification link expires after 24 hours and cannot be used for verification after expiration.",
              "priority": "High",
              "related_requirement_ids": [
                "BR006"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB005",
          "sub_function_name": "Resend Verification Link",
          "description": "User can request to resend the verification link after a 60-second cooldown.",
          "related_requirement_ids": [
            "FR004",
            "DEP002"
          ],
          "test_categories": [
            {
              "category_id": "CAT009",
              "category_name": "Resend Cooldown Enforcement",
              "test_intent": "Verify that the resend request is rejected if attempted within 60 seconds of the previous request, and allowed after the cooldown period.",
              "priority": "High",
              "related_requirement_ids": [
                "FR004",
                "DEP002"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB006",
          "sub_function_name": "Email Verification Before First Login",
          "description": "User must verify email before first login.",
          "related_requirement_ids": [
            "FR002"
          ],
          "test_categories": [
            {
              "category_id": "CAT010",
              "category_name": "Verification Required for Login",
              "test_intent": "Verify that a user cannot log in without having verified their email address.",
              "priority": "High",
              "related_requirement_ids": [
                "FR002"
              ]
            }
          ]
        }
      ]
    }
  ]
}