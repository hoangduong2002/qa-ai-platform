{
  "main_functions": [
    {
      "function_id": "FUNC001",
      "function_name": "Account Registration",
      "description": "Allows a user to create an account using an email and password, with validation and rate limiting.",
      "related_requirement_ids": [
        "FR001",
        "FR005",
        "BR001",
        "BR002",
        "BR003",
        "BR004",
        "BR007",
        "VAL001",
        "VAL002",
        "VAL003",
        "VAL004",
        "VAL005",
        "VAL006",
        "VAL007"
      ],
      "sub_functions": [
        {
          "sub_function_id": "SUB001",
          "sub_function_name": "Email Validation",
          "description": "Validates email format and uniqueness, and blocks disposable email domains.",
          "related_requirement_ids": [
            "FR001",
            "BR001",
            "VAL001",
            "VAL002",
            "VAL007"
          ],
          "test_categories": [
            {
              "category_id": "CAT001",
              "category_name": "Email Format Validation",
              "test_intent": "Verify that email addresses conforming to simplified RFC 5322 are accepted, and non-conforming formats are rejected with appropriate error message.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL001"
              ]
            },
            {
              "category_id": "CAT002",
              "category_name": "Disposable Email Domain Blocking",
              "test_intent": "Verify that registration with email from known disposable email providers is rejected.",
              "priority": "High",
              "related_requirement_ids": [
                "VAL002"
              ]
            },
            {
              "category_id": "CAT003",
              "category_name": "Email Uniqueness Check",
              "test_intent": "Verify that duplicate email registration is rejected with the specified error message.",
              "priority": "High",
              "related_requirement_ids": [
                "BR001",
                "VAL007"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB002",
          "sub_function_name": "Password Validation",
          "description": "Validates password complexity, length, and content rules.",
          "related_requirement_ids": [
            "FR001",
            "BR002",
            "BR003",
            "BR004",
            "VAL003",
            "VAL004",
            "VAL005",
            "VAL006"
          ],
          "test_categories": [
            {
              "category_id": "CAT004",
              "category_name": "Password Length Validation",
              "test_intent": "Verify that passwords between 8 and 64 characters are accepted, and passwords outside this range are rejected with appropriate error message.",
              "priority": "High",
              "related_requirement_ids": [
                "BR002",
                "VAL003"
              ]
            },
            {
              "category_id": "CAT005",
              "category_name": "Password Complexity Validation",
              "test_intent": "Verify that passwords containing at least one uppercase, one lowercase, one digit, and one special character are accepted; missing any required character type is rejected.",
              "priority": "High",
              "related_requirement_ids": [
                "BR003",
                "VAL004"
              ]
            },
            {
              "category_id": "CAT006",
              "category_name": "Password Content Restrictions",
              "test_intent": "Verify that passwords containing spaces or the username are rejected.",
              "priority": "High",
              "related_requirement_ids": [
                "BR004",
                "VAL005",
                "VAL006"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB003",
          "sub_function_name": "Account Creation Rate Limiting",
          "description": "Enforces rate limit on account creation attempts per IP address.",
          "related_requirement_ids": [
            "FR005",
            "BR007"
          ],
          "test_categories": [
            {
              "category_id": "CAT007",
              "category_name": "IP-based Rate Limit Enforcement",
              "test_intent": "Verify that up to 5 account creation attempts per IP within a 15-minute rolling window are allowed, and the 6th attempt is blocked.",
              "priority": "High",
              "related_requirement_ids": [
                "FR005",
                "BR007"
              ]
            },
            {
              "category_id": "CAT008",
              "category_name": "Rate Limit Reset After Window",
              "test_intent": "Verify that after the 15-minute rolling window, the IP can attempt account creation again.",
              "priority": "Medium",
              "related_requirement_ids": [
                "FR005",
                "BR007"
              ]
            }
          ]
        }
      ]
    },
    {
      "function_id": "FUNC002",
      "function_name": "Email Verification",
      "description": "Handles sending verification email, resend requests, and login blocking until verified.",
      "related_requirement_ids": [
        "FR002",
        "FR003",
        "FR004",
        "FR006",
        "FR007",
        "BR005",
        "BR006",
        "BR008",
        "BR009"
      ],
      "sub_functions": [
        {
          "sub_function_id": "SUB004",
          "sub_function_name": "Verification Link Generation and Expiry",
          "description": "Generates a unique verification link valid for 24 hours.",
          "related_requirement_ids": [
            "FR002",
            "BR005"
          ],
          "test_categories": [
            {
              "category_id": "CAT009",
              "category_name": "Verification Link Validity Period",
              "test_intent": "Verify that the verification link is valid for 24 hours and expires after that time.",
              "priority": "High",
              "related_requirement_ids": [
                "BR005"
              ]
            },
            {
              "category_id": "CAT010",
              "category_name": "Unique Link Generation",
              "test_intent": "Verify that each registration generates a unique verification link.",
              "priority": "Medium",
              "related_requirement_ids": [
                "FR002"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB005",
          "sub_function_name": "Resend Verification Email",
          "description": "Allows user to request resend of verification email with cooldown and rate limiting.",
          "related_requirement_ids": [
            "FR003",
            "FR006",
            "FR007",
            "BR006",
            "BR008",
            "BR009"
          ],
          "test_categories": [
            {
              "category_id": "CAT011",
              "category_name": "Resend Cooldown Enforcement",
              "test_intent": "Verify that a resend request is allowed only once every 60 seconds per account.",
              "priority": "High",
              "related_requirement_ids": [
                "BR006"
              ]
            },
            {
              "category_id": "CAT012",
              "category_name": "Resend Rate Limit and Lockout",
              "test_intent": "Verify that after 3 resend requests within 1 hour, the resend feature is locked for 30 minutes for the IP or account.",
              "priority": "High",
              "related_requirement_ids": [
                "FR006",
                "FR007",
                "BR008",
                "BR009"
              ]
            }
          ]
        },
        {
          "sub_function_id": "SUB006",
          "sub_function_name": "Login Blocking for Unverified Accounts",
          "description": "Blocks login attempts for accounts that have not completed email verification.",
          "related_requirement_ids": [
            "FR004"
          ],
          "test_categories": [
            {
              "category_id": "CAT013",
              "category_name": "Login Block Before Verification",
              "test_intent": "Verify that an unverified account cannot log in.",
              "priority": "High",
              "related_requirement_ids": [
                "FR004"
              ]
            },
            {
              "category_id": "CAT014",
              "category_name": "Login Allowed After Verification",
              "test_intent": "Verify that after successful email verification, the account can log in.",
              "priority": "High",
              "related_requirement_ids": [
                "FR004"
              ]
            }
          ]
        }
      ]
    }
  ]
}