    "title": "Username uniqueness - duplicate username rejected",
    "type": "Negative",
    "priority": "High",
    "preconditions": [
      "A user with username 'existinguser' already exists in the system.",
      "User is on the registration page."
    ],
    "test_steps": [
      "Enter first name: John",
      "Enter last name: Doe",
      "Enter username: existinguser",
      "Enter email: newuser@example.com",
      "Enter phone: 1234567890",
      "Enter password: Pass123!",
      "Enter confirm password: Pass123!",
      "Click Submit."
    ],
    "expected_results": [
      "An inline error message appears indicating that the username is already taken."
    ],
    "test_data": {
      "first_name": "John",
      "last_name": "Doe",
      "username": "existinguser",
      "email": "newuser@example.com",
      "phone": "1234567890",
      "password": "Pass123!",
      "confirm_password": "Pass123!"
    },
    "related_requirement_ids": [
      "VAL006",
      "FR004"
    ],
    "traceability": "VAL006, FR004"
  },
