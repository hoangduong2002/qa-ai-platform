# DeepSeek disabled in this sample. Keep empty to avoid remote token usage.
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxx
FIGMA_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

LLM_PROVIDER=LOCAL

# DeepSeek settings are kept for reference only. Do not set fallback to DEEPSEEK
# when running local-only.
DEEPSEEK_ENABLED=false
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TIMEOUT=120

# =========================
# LLM Router
# =========================
# Providers:
# - DEEPSEEK
# - LOCAL_TEXT
# - LOCAL_VISION
# - LOCAL_COMPACT
#
# Local-only routing. Empty fallback means no DeepSeek call.
TEXT_LLM_PRIMARY=LOCAL_TEXT
TEXT_LLM_FALLBACK=

# Compact context uses local Qwen only.
COMPACT_LLM_PRIMARY=LOCAL_COMPACT
COMPACT_LLM_FALLBACK=

# Vision uses local Qwen2.5-VL only.
VISION_LLM_PRIMARY=LOCAL_VISION
VISION_LLM_FALLBACK=

JIRA_SERVER_URL=https://vts.vatech.com
JIRA_AUTH_MODE=PAT

JIRA_VERIFY_SSL=true
JIRA_INCLUDE_SUBTASKS=true

SANITIZE_REQUIREMENT=true
REDACT_EMAILS=true
REDACT_USERS=true
REDACT_ORGANIZATIONS=true
REDACT_URLS=true


TESSERACT_CMD=H:\Tesseract-OCR\tesseract.exe

OCR_LANGUAGE=eng+fra+vie

IMPROVE_FAIL_FAST=false

TESTCASE_PARALLEL_WORKERS=2
TESTCASE_SCENARIO_BATCH_SIZE=5
TESTCASE_BATCH_PARALLEL_WORKERS=2

LOG_LEVEL=WARNING

# =========================
# Local AI / LOCAL
# =========================
# Local-only sample: enabled.
LOCAL_AI_ENABLED=true
LOCAL_AI_PROVIDER=OLLAMA
LOCAL_BASE_URL=http://localhost:11434

# Global local vision switch. Child switches below are only considered when
# LOCAL_AI_ENABLED=true.
LOCAL_VISION_ENABLED=true
FIGMA_LOCAL_VISION_ENABLED=true
ATTACHMENT_LOCAL_VISION_ENABLED=true

# Local compact/text features.
LOCAL_COMPACT_ENABLED=true
LOCAL_TEXT_FALLBACK_ENABLED=true

LOCAL_VISION_MODEL=qwen2.5vl:7b
LOCAL_COMPACT_MODEL=qwen2.5:14b
LOCAL_TEXT_MODEL=qwen2.5:14b
LOCAL_TEXT_BASE_URL=http://localhost:11434
LOCAL_TEXT_TIMEOUT=180
LOCAL_VISION_BASE_URL=http://localhost:11434
LOCAL_VISION_TIMEOUT=240
COMPACT_LLM_MODEL=qwen2.5:14b
COMPACT_LLM_TIMEOUT=180

# LLM router skeleton provider config.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_COMPACT_MODEL=qwen2.5:14b
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# Image extractor selection for attachments. LOCAL uses local AI
# and is gated by LOCAL_AI_ENABLED + ATTACHMENT_LOCAL_VISION_ENABLED.
# TESSERACT does not call local AI.
IMAGE_EXTRACTOR=LOCAL

# =========================
# Requirement Compact Context
# =========================
REQUIREMENT_CHUNK_MAX_CHARS=20000
REQUIREMENT_COMPACT_CONTEXT_MAX_CHARS=60000
REQUIREMENT_COMPACT_MAX_TEXT_ITEMS_PER_SCREEN=10
REQUIREMENT_COMPACT_MAX_SCREEN_NAMES_PER_SECTION=20
REQUIREMENT_COMPACT_MAX_KEY_TEXTS_PER_SECTION=20
REQUIREMENT_COMPACT_MAX_ACTIONS_PER_SECTION=10
REQUIREMENT_COMPACT_MAX_QA_NOTES_PER_SECTION=10
REQUIREMENT_COMPACT_MAX_SCREENS_PER_SECTION_IN_MARKDOWN=50

FIGMA_ENABLE_EXTRACTION=true


FIGMA_EXTRACT_SCOPE=linked_page
FIGMA_ALLOW_FIRST_PAGE_FALLBACK=false

FIGMA_MAX_FILES_PER_TICKET=5
FIGMA_MAX_LAYERS_PER_PAGE=30
FIGMA_MAX_SCREENS_PER_LAYER=50
FIGMA_MAX_SCREENS_PER_PAGE=100

FIGMA_MAX_LAYER_AREA=50000000
FIGMA_MAX_LAYER_WIDTH=20000
FIGMA_MAX_LAYER_HEIGHT=20000

FIGMA_MIN_FRAME_WIDTH=200
FIGMA_MIN_FRAME_HEIGHT=200
FIGMA_MAX_FRAME_AREA=3000000
FIGMA_MAX_FRAME_WIDTH=2500
FIGMA_MAX_FRAME_HEIGHT=2500

FIGMA_PAGE_RESOLVE_DEPTH=4
FIGMA_PAGE_FETCH_DEPTH=3
FIGMA_LAYER_FETCH_DEPTH=4
FIGMA_LAYER_SCAN_DEPTH=3

FIGMA_IMAGE_EXPORT_BATCH_SIZE=1
FIGMA_EXPORT_SCALE=1
FIGMA_EXPORT_FORMAT=png

FIGMA_EXPORT_CONTAINER_LAYERS=false
