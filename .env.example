# ============================================================
# qa-ai-platform environment template
# ============================================================
# Copy this file to .env for non-secret defaults.
# Put real API keys/tokens in .env.secrets.
#
# Recommended files:
# - .env.example   : safe template, can be committed
# - .env           : local non-secret config, do not commit
# - .env.secrets   : API keys/tokens, do not commit
#
# AI routing principle:
# - AI_MODE decides which provider is used for each task.
# - Provider keys only define endpoint/model.
# - FORCE_DISABLE_* keys are emergency kill switches only.
#
# Supported AI modes:
# - PRODUCTION_HYBRID : DeepSeek for text/reasoning, Local/Ollama for compact/vision when available
# - DEEPSEEK_ONLY     : DeepSeek for text/reasoning, skip Local vision
# - TEST_LOCAL_ONLY   : Local/Ollama only, never call DeepSeek
# - NO_LLM            : no LLM calls; only import/extract/rule-based operations


# ============================================================
# Secrets - keep empty here
# ============================================================
# Put real values in .env.secrets.
#
# Required when using DeepSeek:
DEEPSEEK_API_KEY=

# Required when running Telegram bot:
TELEGRAM_BOT_TOKEN=

# Required when Figma extraction is enabled:
FIGMA_ACCESS_TOKEN=

# Jira auth:
# - If JIRA_AUTH_MODE=PAT, use JIRA_PAT.
# - If JIRA_AUTH_MODE=BASIC, use JIRA_USERNAME + JIRA_API_TOKEN or JIRA_PASSWORD.
JIRA_PAT=
JIRA_API_TOKEN=
JIRA_USERNAME=
JIRA_PASSWORD=

# Optional, only if GitHub integration is implemented:
GITHUB_TOKEN=


# ============================================================
# AI Mode presets
# ============================================================
# Choose one preset. Comment/uncomment the whole group as needed.


# ------------------------------------------------------------
# Preset A: Production Hybrid
# Use DeepSeek for text/reasoning.
# Use Local/Ollama for compact/vision when configured.
# Recommended for normal production usage.
# ------------------------------------------------------------
TELEGRAM_AI_MODE=PRODUCTION_HYBRID
PORTAL_DEFAULT_AI_MODE=NO_LLM


# ------------------------------------------------------------
# Preset B: DeepSeek Only
# Use DeepSeek for text/reasoning.
# Do not use Local/Ollama for vision.
# Good when Ollama is not available.
# ------------------------------------------------------------
# TELEGRAM_AI_MODE=DEEPSEEK_ONLY
# PORTAL_DEFAULT_AI_MODE=NO_LLM


# ------------------------------------------------------------
# Preset C: Test Local Only
# Use Local/Ollama for text, compact, and vision.
# Never call DeepSeek.
# Good for development without remote token cost.
# ------------------------------------------------------------
# TELEGRAM_AI_MODE=TEST_LOCAL_ONLY
# PORTAL_DEFAULT_AI_MODE=NO_LLM


# ------------------------------------------------------------
# Preset D: No LLM
# No DeepSeek, no Local/Ollama.
# Analyze/Generate should be blocked.
# Jira/Figma import and rule-based operations may still run.
# ------------------------------------------------------------
# TELEGRAM_AI_MODE=NO_LLM
# PORTAL_DEFAULT_AI_MODE=NO_LLM


# Optional fallback for CLI/scripts not started from Portal/Telegram.
# Leave empty unless code explicitly uses it.
# Values: PRODUCTION_HYBRID, DEEPSEEK_ONLY, TEST_LOCAL_ONLY, NO_LLM
NON_PORTAL_AI_MODE=

# Maximum clarification questions generated in one round.
MAX_CLARIFICATIONS_PER_ROUND=5


# ============================================================
# DeepSeek provider config
# ============================================================
# Used when AI mode routes text/reasoning tasks to DeepSeek.
#
# Supported examples:
# - deepseek-v4-flash : recommended default, cheaper/faster
# - deepseek-v4-pro   : expensive; should require ALLOW_DEEPSEEK_PRO=true
#
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=120

# Safety guard. Keep false unless you intentionally want to use Pro.
ALLOW_DEEPSEEK_PRO=false

# Emergency kill switch.
# If true, DeepSeek calls must be blocked regardless of AI mode.
FORCE_DISABLE_DEEPSEEK=false


# ============================================================
# Local AI provider config
# ============================================================
# LOCAL means an Ollama server available from this app.
# It can run on this machine or another machine in the LAN.
#
# Currently supported value:
# - OLLAMA
#
LOCAL_AI_PROVIDER=OLLAMA

# Examples:
# - Same machine: http://localhost:11434
# - LAN machine : http://172.76.10.44:11434
LOCAL_BASE_URL=http://172.76.10.44:11434

# Local text model for requirement analysis, clarifications,
# scenario/testcase generation when AI mode is TEST_LOCAL_ONLY.
LOCAL_TEXT_MODEL=qwen2.5:14b

# Optional compact model.
# If empty, compact should use LOCAL_TEXT_MODEL.
LOCAL_COMPACT_MODEL=

# Local vision model for Figma frames, Jira attachments, uploaded images.
LOCAL_VISION_MODEL=qwen2.5vl:7b

LOCAL_TEXT_TIMEOUT=180
LOCAL_COMPACT_TIMEOUT=180
LOCAL_VISION_TIMEOUT=240

# Emergency kill switch.
# If true, Local/Ollama calls must be blocked regardless of AI mode.
FORCE_DISABLE_LOCAL_AI=false


# ============================================================
# Jira
# ============================================================
# Main Jira base URL.
# Example: https://your-company.atlassian.net or https://jira.company.com
JIRA_SERVER_URL=

# Auth modes:
# - PAT   : use JIRA_PAT
# - BASIC : use JIRA_USERNAME + JIRA_API_TOKEN or JIRA_PASSWORD
JIRA_AUTH_MODE=PAT

# Values: true, false
JIRA_VERIFY_SSL=true

# Values: true, false
# true = include Jira subtasks in requirement context.
JIRA_INCLUDE_SUBTASKS=true


# ============================================================
# Figma extraction
# ============================================================
# Values: true, false
# true = detect Figma links and extract page/section/frame metadata.
FIGMA_ENABLE_EXTRACTION=false

# Values:
# - linked_page : extract only the page resolved from linked node-id
# - linked_node : extract only linked node scope if supported
# - file        : full file scope; expensive and not recommended for large files
FIGMA_EXTRACT_SCOPE=linked_page

# Values: true, false
# false is safer. Avoid silently extracting wrong first page.
FIGMA_ALLOW_FIRST_PAGE_FALLBACK=false

# Safety limits:
FIGMA_MAX_FILES_PER_TICKET=5
FIGMA_MAX_LAYERS_PER_PAGE=30
FIGMA_MAX_SCREENS_PER_LAYER=50
FIGMA_MAX_SCREENS_PER_PAGE=100

# SECTION/layer safety limits:
FIGMA_MAX_LAYER_AREA=50000000
FIGMA_MAX_LAYER_WIDTH=20000
FIGMA_MAX_LAYER_HEIGHT=20000

# FRAME/screen export filters:
FIGMA_MIN_FRAME_WIDTH=200
FIGMA_MIN_FRAME_HEIGHT=200
FIGMA_MAX_FRAME_AREA=3000000
FIGMA_MAX_FRAME_WIDTH=2500
FIGMA_MAX_FRAME_HEIGHT=2500

# Figma API depth tuning:
FIGMA_PAGE_RESOLVE_DEPTH=4
FIGMA_PAGE_FETCH_DEPTH=3
FIGMA_LAYER_FETCH_DEPTH=4
FIGMA_LAYER_SCAN_DEPTH=3

# Image export tuning:
FIGMA_IMAGE_EXPORT_BATCH_SIZE=1
FIGMA_EXPORT_SCALE=1
FIGMA_EXPORT_FORMAT=png

# Values: true, false
# false = export only FRAME screens, not big SECTION containers.
FIGMA_EXPORT_CONTAINER_LAYERS=false


# ============================================================
# Image analysis policy
# ============================================================
# Tesseract has been removed.
#
# Image analysis uses Local Vision through LOCAL_VISION_MODEL
# when selected AI mode allows Local Vision:
# - TEST_LOCAL_ONLY   : Local Vision allowed
# - PRODUCTION_HYBRID : Local Vision allowed if Local provider is configured
# - DEEPSEEK_ONLY     : Local Vision skipped
# - NO_LLM            : Local Vision skipped
#
# If vision is skipped, image files/frame.png should still be saved
# where applicable, and a skipped marker should be written.


# ============================================================
# Requirement handling
# ============================================================
# Values: true, false
SANITIZE_REQUIREMENT=true

# Redaction switches used during sanitization.
# Values: true, false
REDACT_EMAILS=true
REDACT_USERS=true
REDACT_ORGANIZATIONS=true
REDACT_URLS=true

# Chunk size for source requirement context.
REQUIREMENT_CHUNK_MAX_CHARS=20000

# Maximum final compact context size.
# Higher value = more context but more token usage.
REQUIREMENT_COMPACT_CONTEXT_MAX_CHARS=60000

# Figma/vision compact context limits:
REQUIREMENT_COMPACT_MAX_TEXT_ITEMS_PER_SCREEN=10
REQUIREMENT_COMPACT_MAX_SCREEN_NAMES_PER_SECTION=20
REQUIREMENT_COMPACT_MAX_KEY_TEXTS_PER_SECTION=20
REQUIREMENT_COMPACT_MAX_ACTIONS_PER_SECTION=10
REQUIREMENT_COMPACT_MAX_QA_NOTES_PER_SECTION=10
REQUIREMENT_COMPACT_MAX_SCREENS_PER_SECTION_IN_MARKDOWN=50


# ============================================================
# Generation settings
# ============================================================
# Values: true, false
# true  = stop immediately when improve step fails
# false = keep partial results when possible
IMPROVE_FAIL_FAST=false

# Number of parallel workers for test case generation.
# Higher value can be faster but may increase provider cost and rate-limit risk.
TESTCASE_PARALLEL_WORKERS=2

# Number of scenarios per batch when generating test cases.
TESTCASE_SCENARIO_BATCH_SIZE=5

# Number of parallel workers at batch level.
TESTCASE_BATCH_PARALLEL_WORKERS=2

# Maximum self-review/improve iterations for test case structure.
MAX_STRUCTURE_REVIEW_ITERATIONS=3

# Number of scenario structures per batch.
SCENARIO_STRUCTURE_BATCH_SIZE=5

# Number of workers for scenario generation.
SCENARIO_PARALLEL_WORKERS=2

# Incremental sync threshold.
# If changed source ratio is above this threshold, recommend full regenerate.
# Example: 0.35 = 35%
INCREMENTAL_MAJOR_CHANGE_THRESHOLD=0.35


# ============================================================
# DeepSeek cost safety
# ============================================================
# Optional but recommended.
# These keys should be enforced before making DeepSeek calls.
MAX_DEEPSEEK_CALLS_PER_JOB=20
MAX_DEEPSEEK_INPUT_TOKENS_PER_JOB=300000
MAX_DEEPSEEK_OUTPUT_TOKENS_PER_JOB=100000

# Dry run should log what would be called, but not call DeepSeek.
# Values: true, false
AI_DRY_RUN=false


# ============================================================
# Logging
# ============================================================
# Values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
